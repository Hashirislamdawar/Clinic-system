# Copy this file to ".env" and adjust as needed.

# --- Default: zero-setup SQLite (good for development & demo) -------------- #
DATABASE_URL=sqlite:///./clinic.db

# --- PostgreSQL (the production target). Uncomment and edit to use it. ----- #
# 1. Create the DB & user (psql):
#      CREATE DATABASE clinic_db;
#      CREATE USER clinic_user WITH PASSWORD 'clinic_pass';
#      GRANT ALL PRIVILEGES ON DATABASE clinic_db TO clinic_user;
# 2. Load schema.sql:  psql -U clinic_user -d clinic_db -f schema.sql
# 3. Point the app at it:
# DATABASE_URL=postgresql+psycopg://clinic_user:clinic_pass@localhost:5432/clinic_db
